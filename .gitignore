# --- Dependencies ---
node_modules/
.pnpm-debug.log*

# --- Build & Output ---
# You had both 'dist' and 'build' in your tree; Vite usually uses 'dist'
dist/
build/
stats.html
depcheck-report.json

# --- Environment & Secrets ---
# Use wildcards to catch .env.local, .env.production, etc.
.env*
!.env.example
env.production

# --- Logs ---
# This catches the logs folder and any stray log files in the root
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS / IDE Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
.idea/

# --- Project Specifics ---
material/
# Only ignore .dockerignore if you truly want to manage it differently on every machine
# Usually, .dockerignore IS tracked so the build is consistent.
# .dockerignore 

# --- Scripts ---
# If these contain sensitive production IPs or keys, keep them ignored.
# Otherwise, deployment logic is usually tracked.
scripts/prod-deploy.sh